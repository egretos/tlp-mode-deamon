#!/usr/bin/env python3
from pathlib import Path
from PIL import Image, ImageDraw

def create_icon(mode, size=32):
    img = Image.new("RGBA", (size, size), (0, 0, 0, 0))
    draw = ImageDraw.Draw(img)
    
    if mode == "cold":
        draw.ellipse([2, 2, size-2, size-2], fill="#2196f3", outline="#0d47a1")
        draw.polygon([(16, 6), (20, 14), (26, 16), (20, 18), (16, 26), (12, 18), (6, 16), (12, 14)], fill="white")
    else:
        draw.rectangle([2, 6, size-2, size-2], fill="#4caf50", outline="#1b5e20")
        draw.rectangle([8, 10, 24, 18], fill="#81c784")
        draw.rectangle([8, 20, 24, 26], fill="#81c784")
    
    return img

icons_dir = Path.home() / ".local/share/icons/hicolor/32x32/apps"
icons_dir.mkdir(parents=True, exist_ok=True)

create_icon("cold", 32).save(icons_dir / "tlp-cold.png")
create_icon("desk", 32).save(icons_dir / "tlp-desk.png")

print(f"Created: {icons_dir}/tlp-cold.png and tlp-desk.png")
